# ============================================================
# FieldStay — Environment Variables
# Copy this file to .env.local and fill in all values.
# Never commit .env.local to version control.
# ============================================================

# ------------------------------------------------------------
# SUPABASE
# From: https://supabase.com/dashboard/project/_/settings/api
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ------------------------------------------------------------
# INNGEST
# From: https://app.inngest.com/env/production/manage/keys
# INNGEST_SIGNING_KEY is used to verify webhook payloads.
# INNGEST_EVENT_KEY is used to send events.
# For local dev, these are set automatically by inngest-cli.
# ------------------------------------------------------------
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key

# ------------------------------------------------------------
# RESEND
# From: https://resend.com/api-keys
# ------------------------------------------------------------
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=noreply@fieldstay.app
RESEND_FROM_NAME=FieldStay

# ------------------------------------------------------------
# STRIPE
# From: https://dashboard.stripe.com/apikeys
# STRIPE_WEBHOOK_SECRET: from Dashboard > Webhooks > endpoint (platform events)
# STRIPE_CONNECT_WEBHOOK_SECRET: from Dashboard > Webhooks > endpoint listening
#   to Connect events (separate endpoint/secret from the one above) — verified
#   in app/api/webhooks/stripe-connect/route.ts
# ------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-key
STRIPE_SECRET_KEY=sk_live_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_your-connect-webhook-secret

# Platform fee taken from vendor invoices paid via Stripe Connect, as a percent (e.g. 3 = 3%)
STRIPE_PLATFORM_FEE_PCT=0

# Stripe Price IDs — create monthly and annual prices in the Stripe dashboard
# and paste the price IDs here.
STRIPE_PRICE_STARTER_MONTHLY=price_starter_monthly_id
STRIPE_PRICE_STARTER_ANNUAL=price_starter_annual_id
STRIPE_PRICE_GROWTH_MONTHLY=price_growth_monthly_id
STRIPE_PRICE_GROWTH_ANNUAL=price_growth_annual_id
STRIPE_PRICE_PORTFOLIO_MONTHLY=price_portfolio_monthly_id
STRIPE_PRICE_PORTFOLIO_ANNUAL=price_portfolio_annual_id

# Guidebook sponsor subscription price — read in app/actions/guidebook.ts
# and app/api/webhooks/stripe/route.ts. Missing this throws at checkout time.
STRIPE_PRICE_SPONSOR_MONTHLY=price_sponsor_monthly_id

# ------------------------------------------------------------
# WEB PUSH (VAPID)
# Generate with: node -e "const webpush = require('web-push'); console.log(JSON.stringify(webpush.generateVAPIDKeys(), null, 2))"
# NEXT_PUBLIC_ prefix makes the public key available to the crew app's
# service worker subscription flow (CrewShell).
# ------------------------------------------------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=hello@fieldstay.app
VAPID_CONTACT_EMAIL=admin@fieldstay.app

# ------------------------------------------------------------
# APP
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://app.fieldstay.app

# Dev override (set to http://localhost:3000 in .env.local)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------------------------------------------------------
# KROGER (Grocery Cart Integration)
# From: https://developer.kroger.com/manage/
# ------------------------------------------------------------
KROGER_CLIENT_ID=your-kroger-client-id
KROGER_CLIENT_SECRET=your-kroger-client-secret

# ------------------------------------------------------------
# MAPBOX (Geocoding — properties and vendors)
# From: https://account.mapbox.com/
# ------------------------------------------------------------
MAPBOX_PUBLIC_TOKEN=pk.your-mapbox-token

# ------------------------------------------------------------
# OWNERREZ (PMS Integration — OAuth + webhook auth)
# From: https://developer.ownerrez.com/
# WEBHOOK_USER and WEBHOOK_PASSWORD are credentials YOU define
# when registering the webhook endpoint in the OwnerRez portal.
# ------------------------------------------------------------
OWNERREZ_CLIENT_ID=your-ownerrez-client-id
OWNERREZ_CLIENT_SECRET=your-ownerrez-client-secret
OWNERREZ_WEBHOOK_USER=your-webhook-basic-auth-user
OWNERREZ_WEBHOOK_PASSWORD=your-webhook-basic-auth-password

# ------------------------------------------------------------
# ANTHROPIC (AI — Data Plate OCR + RepuGuard generation)
# From: https://console.anthropic.com/settings/keys
# Required for: /api/assets/scan-data-plate and /api/repuguard/generate
# The SDK reads this key automatically via new Anthropic() — no arg needed.
# A missing key deploys silently and fails only on first user request.
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-key

# RepuGuard's model, kept out of code so a model retirement is a config
# change, not a silent outage (see lib/repuguard/generate-response.ts).
# Must be set in every environment (local, Vercel preview, Vercel production)
# — the code falls back to 'claude-sonnet-5' if unset, but don't rely on that.
REPUGUARD_MODEL=claude-sonnet-5

# ------------------------------------------------------------
# OPENAI — used for support bot knowledge base embeddings (text-embedding-3-small)
# From: https://platform.openai.com/api-keys
# ------------------------------------------------------------
OPENAI_API_KEY=

# ------------------------------------------------------------
# UPSTASH (Rate Limiting — RepuGuard, data plate scanning, OwnerRez
# sync, and the public /wo/[token] work order page + sign-off action)
# From: https://console.upstash.com/redis
# Note: Vercel KV uses non-standard lowercase var names.
# ------------------------------------------------------------
upstash_fieldstay_KV_REST_API_URL=https://your-instance.upstash.io
upstash_fieldstay_KV_REST_API_TOKEN=your-token

# ------------------------------------------------------------
# TELNYX (Guidebook guest SMS — outbound nudges + inbound STOP/START)
# From: https://portal.telnyx.com → API Keys
# Outbound sends (lib/sms/telnyx.ts) require the API key, messaging
# profile, and from number. Inbound webhook signature verification
# (/api/webhooks/telnyx) requires the Ed25519 public key — without it,
# verifyTelnyxSignature() fails closed and rejects every webhook.
# ------------------------------------------------------------
TELNYX_API_KEY=your-telnyx-api-key
TELNYX_MESSAGING_PROFILE_ID=your-messaging-profile-id
TELNYX_FROM_NUMBER=+15555555555
TELNYX_WEBHOOK_PUBLIC_KEY=    # Ed25519 public key from Telnyx Portal → API Keys

# ------------------------------------------------------------
# SENTRY (Errors + performance traces + Application Metrics)
# From: https://sentry.io/settings/<org>/projects/<project>/keys/
# Read by instrumentation.ts, instrumentation-client.ts, every
# reportError() call site (lib/observability/report-error.ts), and every
# incrementCounter()/recordGauge() call site (lib/observability/metrics.ts —
# Sentry.metrics, no separate credential needed).
# ------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=https://your-key@o0.ingest.sentry.io/0

# SENTRY_ORG / SENTRY_PROJECT / SENTRY_AUTH_TOKEN are read by
# withSentryConfig() in next.config.ts at build time — only used to upload
# source maps for symbolicated stack traces. Required in CI/Vercel;
# a missing SENTRY_AUTH_TOKEN just skips the upload step locally rather
# than failing the build, so these are optional for local dev.
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=your-sentry-project-slug
SENTRY_AUTH_TOKEN=sntrys_your-auth-token

# ------------------------------------------------------------
# SMS (Guest SMS master kill switch)
# Gates every send in lib/sms/telnyx.ts. Must stay 'false' until 10DLC
# campaign verification clears — see CLAUDE.md "SMS — Gate on SMS_ENABLED".
# ------------------------------------------------------------
SMS_ENABLED=false

# ------------------------------------------------------------
# TOMORROW.IO (Weather — contextual guest SMS signals)
# From: https://app.tomorrow.io/development/keys
# Required for: lib/weather/tomorrow.ts — throws if unset when called.
# ------------------------------------------------------------
TOMORROW_IO_API_KEY=your-tomorrow-io-api-key

# ------------------------------------------------------------
# HOSPITABLE (PMS Integration — OAuth + webhook auth)
# From: https://developer.hospitable.com/
# Required for: lib/integrations/providers/hospitable.ts and
# hospitable-token.ts — both throw at runtime if unset.
# ------------------------------------------------------------
HOSPITABLE_CLIENT_ID=your-hospitable-client-id
HOSPITABLE_CLIENT_SECRET=your-hospitable-client-secret
HOSPITABLE_WEBHOOK_SECRET=your-hospitable-webhook-secret
