# ============================================================
# FieldStay — Environment Variables
# Copy this file to .env.local and fill in all values.
# Never commit .env.local to version control.
# ============================================================

# ------------------------------------------------------------
# SUPABASE
# From: https://supabase.com/dashboard/project/_/settings/api
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ------------------------------------------------------------
# INNGEST
# From: https://app.inngest.com/env/production/manage/keys
# INNGEST_SIGNING_KEY is used to verify webhook payloads.
# INNGEST_EVENT_KEY is used to send events.
# For local dev, these are set automatically by inngest-cli.
# ------------------------------------------------------------
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key

# ------------------------------------------------------------
# RESEND
# From: https://resend.com/api-keys
# ------------------------------------------------------------
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=noreply@fieldstay.app
RESEND_FROM_NAME=FieldStay

# ------------------------------------------------------------
# STRIPE
# From: https://dashboard.stripe.com/apikeys
# STRIPE_WEBHOOK_SECRET: from Dashboard > Webhooks > endpoint
# ------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-key
STRIPE_SECRET_KEY=sk_live_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Stripe Price IDs — create monthly and annual prices in the Stripe dashboard
# and paste the price IDs here.
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly_id
STRIPE_PRICE_PRO_ANNUAL=price_pro_annual_id
STRIPE_PRICE_GROWTH_MONTHLY=price_growth_monthly_id
STRIPE_PRICE_GROWTH_ANNUAL=price_growth_annual_id

# ------------------------------------------------------------
# POWERSYNC
# From: https://app.powersync.com/project/_/instances
# ------------------------------------------------------------
NEXT_PUBLIC_POWERSYNC_URL=https://your-instance.powersync.journey.tech

# ------------------------------------------------------------
# WEB PUSH (VAPID)
# Generate with: node -e "const webpush = require('web-push'); console.log(JSON.stringify(webpush.generateVAPIDKeys(), null, 2))"
# NEXT_PUBLIC_ prefix makes the public key available to the crew app's
# service worker subscription flow (CrewShell).
# ------------------------------------------------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=hello@fieldstay.app

# ------------------------------------------------------------
# APP
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://app.fieldstay.app

# Dev override (set to http://localhost:3000 in .env.local)
# NEXT_PUBLIC_APP_URL=http://localhost:3000
