# Copy to e2e/.env.e2e (gitignored — never commit real values here).
#
# E2E_PM_* must be a real Supabase Auth account whose org has completed all
# 8 onboarding steps and has plan_status = 'active' (or an unexpired trial) —
# see e2e/global-setup.ts for the exact failure messages if either isn't true.
#
# E2E_CREW_* is created automatically on first run via the Supabase Admin API
# if it doesn't already exist (see seedCrewLoginAndAssignment in global-setup.ts).
E2E_PM_EMAIL=your-e2e-pm-account@example.com
E2E_PM_PASSWORD=change-me
E2E_CREW_EMAIL=your-e2e-crew-account@example.com
E2E_CREW_PASSWORD=change-me

# Defaults to http://localhost:3000 (playwright.config.ts starts a local dev
# server automatically in that case). Point at a deployed preview URL instead
# to run E2E against a real environment without a local server.
E2E_BASE_URL=http://localhost:3000
